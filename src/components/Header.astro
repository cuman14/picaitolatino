---

<header class="header" id="top">
  <div class="container header-content">
    <a href="/" class="logo">
      <img src="/logo.jpg" alt="Picaito Latino" class="logo-image" />
    </a>

    <div class="header-right">
      <button
        id="lang-toggle"
        class="lang-toggle-btn"
        aria-label="Cambiar idioma / Change language"
      >
        <span class="lang-text lang-es-text current">ES</span>
        <span class="lang-separator">/</span>
        <span class="lang-text lang-en-text">EN</span>
      </button>
    </div>
  </div>
</header>

<script>
  // Setup language toggle functionality
  function setupLangToggle() {
    const toggleBtn = document.getElementById("lang-toggle");
    const htmlEl = document.documentElement;

    if (!toggleBtn) return;

    // Sincronizar UI con el idioma ya establecido (por Layout o localStorage)
    const currentLang = htmlEl.getAttribute("lang") || "es";
    updateToggleUI(currentLang);

    toggleBtn.addEventListener("click", () => {
      const currentLang = htmlEl.getAttribute("lang") || "es";
      const newLang = currentLang === "es" ? "en" : "es";

      htmlEl.setAttribute("lang", newLang);
      localStorage.setItem("picaito_lang", newLang);
      updateToggleUI(newLang);
    });

    function updateToggleUI(lang) {
      const esText = toggleBtn.querySelector(".lang-es-text");
      const enText = toggleBtn.querySelector(".lang-en-text");

      if (lang === "es") {
        esText.classList.add("current");
        enText.classList.remove("current");
      } else {
        esText.classList.remove("current");
        enText.classList.add("current");
      }
    }
  }

  // Header scroll effect
  function setupHeaderScroll() {
    const header = document.querySelector(".header");
    if (!header) return;

    window.addEventListener("scroll", () => {
      if (window.scrollY > 20) {
        header.classList.add("scrolled");
      } else {
        header.classList.remove("scrolled");
      }
    });
  }

  // Run on initial load
  document.addEventListener("DOMContentLoaded", () => {
    setupLangToggle();
    setupHeaderScroll();
  });
</script>

<style>
  .header {
    height: 70px;
    background-color: var(--color-bg-paper);
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    display: flex;
    align-items: center;
    position: sticky;
    top: 0;
    z-index: 100;
    transition: all 0.3s ease;
  }

  .header.scrolled {
    background-color: rgba(253, 250, 248, 0.8);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    height: 60px;
    box-shadow: var(--shadow-sm);
    border-bottom-color: var(--glass-border);
  }

  .header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .logo {
    display: flex;
    align-items: center;
    line-height: 1;
  }

  /* Create a container for the language toggle to balance the flex layout */
  .header-right {
    flex: 1;
    display: flex;
    justify-content: flex-end;
  }

  .logo-image {
    height: 48px;
    width: 48px;
    object-fit: cover;
    border-radius: 10px; /* Bordes ligeramente redondeados (tipo app) */
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
  }

  /* When header is scrolled, make the logo slightly smaller */
  :global(.header.scrolled) .logo-image {
    height: 40px;
    width: 40px;
  }

  .icon-btn {
    color: var(--color-primary);
    padding: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s;
  }

  .icon-btn:active {
    transform: scale(0.9);
  }

  .lang-toggle-btn {
    display: flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-dark);
    padding: 8px;
    opacity: 0.8;
    transition: opacity 0.2s;
  }

  .lang-toggle-btn:hover {
    opacity: 1;
  }

  .lang-text {
    transition: color 0.2s;
  }

  .lang-text.current {
    color: var(--color-primary);
    font-weight: 700;
  }

  .lang-separator {
    color: var(--color-secondary);
    font-weight: 400;
  }
</style>
