---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import BottomNav from '../components/BottomNav.astro';
import DishCard from '../components/DishCard.astro';
import CategoryCard from '../components/CategoryCard.astro';
import { menuData } from '../data/menu';

const categories = menuData.filter(c => c.id !== 'especiales');

// Imágenes para las categorías (usando placeholders premium por ahora)
const categoryImages: Record<string, string> = {
  'empezar': '/cat_empezar.png',
  'raciones': '/cat_raciones.png',
  'tostas': 'https://images.unsplash.com/photo-1525351484163-7529414344d8?q=80&w=800&auto=format&fit=crop',
  'mini-tortillas': 'https://images.unsplash.com/photo-1510693206972-df098062cb71?q=80&w=800&auto=format&fit=crop',
  'postres': 'https://images.unsplash.com/photo-1551024506-0bccd828d307?q=80&w=800&auto=format&fit=crop',
  'bebidas': 'https://images.unsplash.com/photo-1551024709-8f23befc6f87?q=80&w=800&auto=format&fit=crop',
};
---

<Layout title="Picaito Latino - Nuestra Carta">
  <Header />
  
  <main class="menu-page">
    <section class="menu-header bg-forest container fade-in">
      <h1>
        <span class="lang-es">Nuestra Carta</span>
        <span class="lang-en">Our Menu</span>
      </h1>
      <p>
        <span class="lang-es">Explora nuestras categorías</span>
        <span class="lang-en">Explore our categories</span>
      </p>
    </section>

    <div class="container categories-grid fade-in delay-1">
      {categories.map((cat, index) => (
        <div class={`grid-item item-${index}`}>
          <CategoryCard 
            id={cat.id} 
            name={cat.name} 
            image={categoryImages[cat.id]} 
          />
        </div>
      ))}
    </div>

    <div class="container menu-content">
      {categories.map(category => (
        <section id={category.id} class="category-section fade-in">
          <div class="section-header">
            <h2 class="category-title">
              <span class="lang-es">{category.name.es}</span>
              <span class="lang-en">{category.name.en}</span>
            </h2>
            <div class="section-divider"></div>
          </div>
          <div class="dishes-list">
            {category.items.map(dish => (
              <DishCard {...dish} />
            ))}
          </div>
        </section>
      ))}
    </div>
    
    <section class="container allergens-legend fade-in">
      <div class="glass-card legend-box">
        <h4>
          <span class="lang-es">Información sobre Alérgenos</span>
          <span class="lang-en">Allergen Information</span>
        </h4>
        <p class="text-muted">
          <span class="lang-es">Consulte con nuestro personal si tiene alguna intolerancia alimentaria.</span>
          <span class="lang-en">Please consult our staff if you have any food intolerances.</span>
        </p>
      </div>
    </section>

    <div class="extra-space"></div>
  </main>

  <BottomNav />
</Layout>

<style>
  .menu-page {
    background-color: var(--color-bg-paper);
    padding-bottom: 100px;
  }

  .menu-header {
    padding: 3rem 1rem;
    text-align: center;
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
    margin-bottom: 2.5rem;
    background: linear-gradient(135deg, var(--color-primary) 0%, #003018 100%);
    box-shadow: var(--shadow-md);
  }

  .menu-header h1 {
    color: var(--color-secondary);
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
    letter-spacing: 3px;
    text-transform: uppercase;
  }

  .menu-header p {
    color: rgba(255, 255, 255, 0.8);
    font-size: 1rem;
    letter-spacing: 1px;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-auto-rows: 160px;
    gap: 1rem;
    margin-bottom: 4rem;
  }

  .grid-item {
    width: 100%;
    height: 100%;
  }

  /* Bento Grid Spanning */
  .item-0 { grid-column: span 2; grid-row: span 1; }
  .item-1 { grid-column: span 1; grid-row: span 2; }
  .item-2 { grid-column: span 1; grid-row: span 1; }
  .item-3 { grid-column: span 1; grid-row: span 1; }
  .item-4 { grid-column: span 2; grid-row: span 1; }
  .item-5 { grid-column: span 1; grid-row: span 1; }

  .category-section {
    padding: 4rem 0 2rem;
    scroll-margin-top: 20px;
  }

  .section-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .category-title {
    font-size: 2rem;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 0.5rem;
  }

  .dishes-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .allergens-legend {
    margin-top: 4rem;
  }

  .legend-box {
    padding: 1.5rem;
    text-align: center;
    border-radius: var(--radius-md);
  }

  .legend-box h4 {
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .legend-box p {
    font-size: 0.85rem;
  }

  .extra-space {
    height: 120px;
  }

  @media (min-width: 768px) {
    .dishes-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
