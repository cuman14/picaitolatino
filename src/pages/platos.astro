---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import BottomNav from '../components/BottomNav.astro';
import DishCard from '../components/DishCard.astro';
import { menuData } from '../data/menu';

const especiales = menuData.find(c => c.id === 'especiales')?.items || [];
---

<Layout title="Picaito Latino - Platos Especiales" description="Nuestra selección más premium de platos latinos modernos.">
  <Header />
  
  <main class="especiales-page">
    <div class="bg-overlay"></div>
    <img src="/bg_especiales.png" alt="Fondo Elegante" class="page-bg" />

    <section class="container content">
      <div class="title-box">
        <p class="pre-title">
          <span class="lang-es">LA SELECCIÓN DEL CHEF</span>
          <span class="lang-en">THE CHEF'S SELECTION</span>
        </p>
        <h1>
          <span class="lang-es">PLATOS ESPECIALES</span>
          <span class="lang-en">CHEF SPECIALS</span>
        </h1>
        <div class="divider"></div>
      </div>

      <div class="dishes-list">
        {especiales.map(dish => (
          <div class="special-item">
            <DishCard {...dish} isDark={true} />
          </div>
        ))}
      </div>
    </section>

    <div class="extra-space"></div>
  </main>

  <BottomNav />
</Layout>

<style>
  .especiales-page {
    position: relative;
    min-height: 100vh;
    padding-bottom: 80px;
    background-color: #0a0a0a;
    color: white;
  }

  .page-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    opacity: 0.4;
  }

  .bg-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle, transparent 20%, #000 100%);
    z-index: 1;
  }

  .content {
    position: relative;
    z-index: 2;
    padding-top: 3rem;
  }

  .title-box {
    text-align: center;
    margin-bottom: 3rem;
  }

  .pre-title {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    letter-spacing: 4px;
    color: var(--color-secondary);
    margin-bottom: 0.5rem;
  }

  h1 {
    font-size: 2.5rem;
    color: white;
    letter-spacing: 2px;
  }

  .divider {
    width: 60px;
    height: 3px;
    background: var(--color-secondary);
    margin: 1.5rem auto;
  }

  .dishes-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .special-item {
    background: rgba(255, 255, 255, 0.03);
    padding: 0 1rem;
    border-radius: var(--radius-md);
    border: 1px solid rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(5px);
  }

  .extra-space {
    height: 50px;
  }
</style>
