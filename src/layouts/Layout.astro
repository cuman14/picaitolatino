---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Picaito Latino - Menú Digital QR" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <!-- Detectar idioma del dispositivo antes de cargar -->
    <script is:inline>
      (function () {
        // Si ya hay preferencia guardada, respetarla
        const savedLang = localStorage.getItem("picaito_lang");
        if (savedLang) {
          document.documentElement.setAttribute("lang", savedLang);
          return;
        }

        // Detectar idioma del navegador
        const browserLang =
          navigator.language || navigator.languages?.[0] || "es";
        const preferredLang = browserLang.toLowerCase().startsWith("en")
          ? "en"
          : "es";

        document.documentElement.setAttribute("lang", preferredLang);
        localStorage.setItem("picaito_lang", preferredLang);
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/jpeg" href="/favicon.jpg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&family=Noto+Serif:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
